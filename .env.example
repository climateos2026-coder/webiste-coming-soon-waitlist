# Site Configuration
# Used by metadata, sitemap, and canonical URLs.
NEXT_PUBLIC_SITE_URL=https://climateos2026.vercel.app

# Supabase Configuration
# Get these from https://app.supabase.com -> Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Supabase Database Schema
# Required table: waitlist
#
# Table: waitlist
# Columns:
#   - id: uuid (primary key, default: gen_random_uuid())
#   - name: text (not null)
#   - email: text (not null, unique)
#   - country: text (nullable)
#   - role: text (nullable)
#   - track_interests: text[] (nullable, default: '{}')
#   - climate_problem: text (nullable)
#   - referral_source: text (nullable)
#   - created_at: timestamp with time zone (default: now())
#
# Enable Row Level Security (RLS) on the waitlist table
# Policy: Allow insert for anonymous users, no select/update/delete

# Brevo (Email) Configuration
# Get from https://app.brevo.com -> Settings -> API Keys
BREVO_API_KEY=your-brevo-api-key
BREVO_FROM_EMAIL=hello@climateoshack.dev
BREVO_FROM_NAME=ClimateOS 2026

# Devfolio Webhook (for registration integration)
# Get from Devfolio dashboard
DEVFOLIO_WEBHOOK_SECRET=your-webhook-secret

# Plausible Analytics (Optional)
# Get from https://plausible.io
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=climateoshack.dev
NEXT_PUBLIC_PLAUSIBLE_URL=https://plausible.yourserver.com

# Event Phase Configuration
# Values: waitlist | registration | pre-hack | sprint | judging | complete
NEXT_PUBLIC_EVENT_PHASE=waitlist

# Registration Form (Optional)
# Defaults to the embedded Google Form URL used by components/sections/waitlist-section.tsx.
# NEXT_PUBLIC_REGISTRATION_FORM_URL=https://docs.google.com/forms/d/e/.../viewform?embedded=true
